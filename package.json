{
  "name": "jouleops",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=__tests__"
  },
  "dependencies": {
    "@expo/vector-icons": "~15.0.3",
    "@journeyapps/react-native-quick-sqlite": "^2.5.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/elements": "2.9.2",
    "@react-navigation/native": "^7.2.1",
    "@rneui/themed": "^5.0.0",
    "@shopify/flash-list": "2.0.2",
    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.0",
    "expo": "^55.0.0",
    "expo-auth-session": "~55.0.16",
    "expo-background-task": "~55.0.18",
    "expo-camera": "~55.0.19",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-task-manager": "~55.0.16",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "firebase": "^12.11.0",
    "jsqr": "^1.4.0",
    "lucide-react-native": "^0.554.0",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "^1.21.8",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-signature-canvas": "^5.0.2",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/base64-arraybuffer": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/uuid": "^11.0.0",
    "babel-preset-expo": "~55.0.22",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~55.0.1",
    "fast-check": "^4.6.0",
    "fs-extra": "^11.3.4",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript",
        "@shopify/flash-list",
        "drizzle-orm",
        "@react-navigation/native"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-vector-icons",
          "@journeyapps/react-native-quick-sqlite"
        ]
      }
    }
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|date-fns|drizzle-orm)"
    ],
    "moduleNameMapper": {
      "^expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/expoImportMetaRegistry.js",
      "^expo/src/winter$": "<rootDir>/__mocks__/expoWinter.js",
      "^expo/src/winter/runtime\\.native$": "<rootDir>/__mocks__/expoWinter.js"
    }
  },
  "overrides": {
    "react-test-renderer": "19.2.0"
  }
}
