{
  "expo": {
    "name": "smart-ops",
    "slug": "smart-ops",
    "version": "1.0.0 (Beta)",
    "orientation": "portrait",
    "icon": "./assets/images/jouleops-icon.png",
    "scheme": "jouleops",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/d1868472-0103-49d5-978e-ece327af4c3e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arundev2025.jouleops"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/jouleops-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.arundev2025.jouleops"
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Jouleops-splash-screen.png",
          "resizeMode": "cover",
          "dark": {
            "image": "./assets/images/Jouleops-splash-screen.png",
            "resizeMode": "cover"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SmartOps needs your location to log attendance at your work site."
        }
      ],
      "expo-task-manager",
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d1868472-0103-49d5-978e-ece327af4c3e"
      }
    }
  }
}
