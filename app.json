{
  "expo": {
    "name": "Jouleops",
    "slug": "smart-ops",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/jouleops-icon.png",
    "scheme": "jouleops",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arundev2025.jouleops",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/jouleops-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.arundev2025.jouleops",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/jouleops-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#b91c1c",
          "dark": {
            "image": "./assets/images/jouleops-icon.png",
            "imageWidth": 150,
            "resizeMode": "contain",
            "backgroundColor": "#b91c1c"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Jouleops needs your location to log attendance at your work site."
        }
      ],
      "expo-task-manager",
      "expo-background-fetch",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Jouleops needs camera access to scan QR codes on assets."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d1868472-0103-49d5-978e-ece327af4c3e"
      },
      "firebaseApiKey": "AIzaSyC2aHsudx0TvfTBj1aV-IZ0cA6b8ohG6Zk",
      "firebaseAuthDomain": "jouleops.firebaseapp.com",
      "firebaseProjectId": "jouleops",
      "firebaseStorageBucket": "jouleops.firebasestorage.app",
      "firebaseMessagingSenderId": "49892025677",
      "firebaseAppId": "1:49892025677:web:7b18d1b734d0a07ce5c304"
    },
    "owner": "smartjoules-ops",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d1868472-0103-49d5-978e-ece327af4c3e",
      "fallbackToCacheTimeout": 10000
    }
  }
}